      "description": "Motor hizi (RPM)"
    },
    {
      "name": "MotorRunning",
      "deviceName": "PLC1",
      "areaType": "DB",
      "dbNumber": 1,
      "startIndex": 4,
      "dataType": "BOOL",
      "bitNo": 0,
      "description": "Motor calisiyor mu"
    },
    {
      "name": "Temperature",
      "deviceName": "PLC1",
      "areaType": "DB",
      "dbNumber": 2,
      "startIndex": 0,
      "dataType": "REAL",
      "bitNo": 0,
